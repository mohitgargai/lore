{
  "name": "lore",
  "version": "0.0.1",
  "description": "In-repo, agent-native tacit knowledge for coding agents: facts the code can't show, surfaced to Claude Code at session start and right before edits.",
  "keywords": [
    "claude-code",
    "coding-agent",
    "ai",
    "context",
    "documentation",
    "adr",
    "knowledge",
    "hooks"
  ],
  "homepage": "https://github.com/mohitgargai/lore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohitgargai/lore.git"
  },
  "bugs": {
    "url": "https://github.com/mohitgargai/lore/issues"
  },
  "license": "Apache-2.0",
  "author": "Mohit Garg",
  "type": "module",
  "bin": {
    "lore": "dist/cli.js"
  },
  "files": [
    "dist",
    "eval"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
